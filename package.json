{
  "name": "isotopes",
  "version": "0.1.0",
  "description": "Lightweight, self-hostable AI agent framework",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "discord",
    "openai"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@openai/agents": "^0.0.7",
    "discord.js": "^14.16.0",
    "openai": "^4.77.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  }
}
